{
  "schema_version": "altanova.automation_contract.v0.4",
  "app": {
    "name": "Picvanta",
    "package": "com.gassticker",
    "main_activity": "com.gassticker.MainActivity"
  },
  "stable_id_format": "contentDescription: id:<stable-id> role:<role>",
  "automation_api": {
    "broadcast_action": "com.gassticker.AUTOMATION",
    "receiver": "com.gassticker/.AutomationReceiver",
    "result_mode": "ordered_broadcast_result_data_json",
    "adb_template": "adb shell am broadcast -n com.gassticker/.AutomationReceiver -a com.gassticker.AUTOMATION --es command <command> [--es key value | --ef key value]",
    "dump_commands": [
      { "command": "dump_contract", "output_file": "files/automation-contract.json" },
      { "command": "dump_state", "output_file": "files/automation-state.json" },
      { "command": "get_state", "description": "Return live runtime state as JSON result data." },
      { "command": "dump_runtime_state", "output_file": "files/automation-runtime-state.json" }
    ],
    "runtime_commands": [
      { "command": "open_editor", "description": "Navigate from Home to editor." },
      { "command": "open_sticker_editor", "description": "Navigate to Sticker Editor mode with text and style controls." },
      { "command": "open_remove_bg_editor", "aliases": ["open_remove_bg"], "description": "Navigate to Remove BG mode without text/font/style controls." },
      { "command": "navigate_home", "description": "Navigate back to Home." },
      { "command": "open_gallery", "aliases": ["pick_image"], "description": "Open the system image picker for manual gallery selection." },
      { "command": "load_sample_image", "description": "Load an internal sample image for repeatable automation tests." },
      { "command": "load_image_path", "args": { "path": "Absolute image path readable by the app process" } },
      { "command": "load_image_uri", "args": { "uri": "Android content/file URI readable by the app" } },
      { "command": "set_tab", "args": { "tab": "select|add|cut|text|style|export" } },
      { "command": "set_text", "args": { "text": "Sticker text, max 18 characters" } },
      { "command": "move_text", "args": { "direction": "up|down|left|right", "step": "optional float pixels" } },
      { "command": "move_text", "args": { "dx": "float pixels", "dy": "float pixels" } },
      { "command": "reset_text_position" },
      { "command": "set_font", "args": { "font": "Font display name or stable slug" } },
      { "command": "set_text_style", "args": { "style": "stroke|shadow|bubble|pop|neon|candy|comic|gold|stamp" } },
      { "command": "set_font_color", "args": { "color": "RRGGBB or #RRGGBB" } },
      { "command": "set_text_style_color", "args": { "color": "RRGGBB or #RRGGBB" } },
      { "command": "set_border_color", "aliases": ["set_outline_color"], "args": { "color": "RRGGBB or #RRGGBB" } },
      { "command": "set_border_width", "aliases": ["set_outline_width"], "args": { "width": "4..28" } },
      { "command": "set_brush_size", "args": { "size": "0.015..0.12" } },
      { "command": "magic_select", "args": { "x": "0..1 normalized image X", "y": "0..1 normalized image Y" }, "async": true },
      { "command": "select_full_image", "description": "Create a full-image selection for deterministic export/style tests." },
      { "command": "clear_selection" },
      { "command": "brush_stroke", "args": { "mode": "add|cut", "points": "x,y;x,y normalized path", "size": "optional 0.015..0.12" } },
      { "command": "brush_stroke", "args": { "mode": "add|cut", "points_json": "[{\"x\":0.4,\"y\":0.4},{\"x\":0.5,\"y\":0.5}]" } },
      { "command": "undo" },
      { "command": "redo" },
      { "command": "compose_sticker", "async": true },
      { "command": "save_png", "aliases": ["export_png"], "async": true, "description": "Save current PNG to Pictures/Picvanta." },
      { "command": "reset_style" }
    ]
  },
  "screens": [
    {
      "id": "screen.home",
      "role": "screen",
      "description": "Home screen with app tool grid."
    },
    {
      "id": "screen.editor",
      "role": "screen",
      "description": "Main editor screen for image pick, selection, text/style editing, and export."
    }
  ],
  "stable_ids": [
    { "id": "menu.sticker_editor", "role": "button", "description": "Home grid entry for Sticker Editor mode." },
    { "id": "menu.remove_bg_editor", "role": "button", "description": "Home grid entry for Remove BG mode." },
    { "id": "command.home", "role": "button", "description": "Return from the editor to the Home screen." },
    { "id": "panel.source_picker", "role": "panel", "description": "Top image editor and source picker panel." },
    { "id": "panel.editor_tools", "role": "panel", "description": "Bottom tabbed editor controls panel." },
    { "id": "status.editor", "role": "status", "description": "Current editor instruction or processing status." },
    { "id": "command.open_image", "role": "button", "description": "Open or replace source image from gallery." },
    { "id": "dropzone.open_image", "role": "button", "description": "Empty editor area; tap to open source image." },
    { "id": "canvas.image_editor", "role": "canvas", "description": "Interactive image canvas for magic select, brush add/cut, zoom, and pan." },
