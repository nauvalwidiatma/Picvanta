  "primary_flows": [
    {
      "id": "flow.create_sticker",
      "steps": [
        "menu.sticker_editor",
        "command.open_image or dropzone.open_image",
        "canvas.image_editor",
        "tab.text",
        "input.sticker_text",
        "tab.style",
        "tab.export",
        "command.save"
      ]
    },
    {
      "id": "flow.remove_background",
      "steps": [
        "menu.remove_bg_editor",
        "command.open_image or dropzone.open_image",
        "canvas.image_editor",
        "tab.add or tab.cut",
        "tab.export",
        "command.save"
      ]
    },
    {
      "id": "flow.refine_selection",
      "steps": [
        "tab.add or tab.cut",
        "control.brush_size",
        "canvas.image_editor",
        "command.undo or command.redo"
      ]
    }
  ]
}
