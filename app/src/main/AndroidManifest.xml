<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- MediaPipe's transitive libraries declare these, but Picvanta is strictly on-device. -->
    <uses-permission
        android:name="android.permission.INTERNET"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.GasSticker">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
